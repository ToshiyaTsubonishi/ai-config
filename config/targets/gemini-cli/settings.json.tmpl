{
  "mcpServers": {
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "env": {}
    },
    "git": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-git"
      ],
      "env": {}
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {}
    },
    "sequential_thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {}
    },
    "time": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-time",
        "--local-timezone={{MCP_LOCAL_TIMEZONE}}"
      ],
      "env": {}
    },
    "gdrive": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-gdrive"
      ],
      "env": {}
    },
    "google_maps": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-google-maps"
      ],
      "env": {
        "GOOGLE_MAPS_API_KEY": "{{GOOGLE_MAPS_API_KEY}}"
      }
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "{{POSTGRES_CONNECTION_STRING}}"
      ],
      "env": {}
    },
    "slack": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-slack"
      ],
      "env": {
        "SLACK_BOT_TOKEN": "{{SLACK_BOT_TOKEN}}",
        "SLACK_TEAM_ID": "{{SLACK_TEAM_ID}}"
      }
    },
    "sqlite": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sqlite",
        "{{SQLITE_DB_PATH}}"
      ],
      "env": {}
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {}
    },
    "chrome_devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "env": {}
    },
    "figma": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.figma.com/mcp"
      ],
      "env": {}
    },
    "github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{{GITHUB_PERSONAL_ACCESS_TOKEN}}"
      }
    },
    "apify": {
      "command": "npx",
      "args": [
        "-y",
        "@apify/actors-mcp-server"
      ],
      "env": {
        "APIFY_TOKEN": "{{APIFY_TOKEN}}"
      }
    },
    "box": {
      "command": "npx",
      "args": [
        "-y",
        "@box/mcp-server-box"
      ],
      "env": {
        "BOX_CLIENT_ID": "{{BOX_CLIENT_ID}}",
        "BOX_CLIENT_SECRET": "{{BOX_CLIENT_SECRET}}",
        "BOX_ENTERPRISE_ID": "{{BOX_ENTERPRISE_ID}}",
        "BOX_USER_ID": "{{BOX_USER_ID}}",
        "BOX_PUBLIC_KEY_ID": "{{BOX_PUBLIC_KEY_ID}}",
        "BOX_PRIVATE_KEY": "{{BOX_PRIVATE_KEY}}",
        "BOX_PASSPHRASE": "{{BOX_PASSPHRASE}}",
        "BOX_APP_SETTINGS_JSON": "{{BOX_APP_SETTINGS_JSON}}",
        "BOX_ACCESS_TOKEN": "{{BOX_ACCESS_TOKEN}}"
      }
    },
    "canva": {
      "command": "npx",
      "args": [
        "-y",
        "@canva/dev-mcp-server"
      ],
      "env": {}
    },
    "firebase": {
      "command": "npx",
      "args": [
        "-y",
        "firebase-tools",
        "experimental:mcp"
      ],
      "env": {
        "FIREBASE_TOKEN": "{{FIREBASE_TOKEN}}"
      }
    },
    "cloud_run": {
      "command": "npx",
      "args": [
        "-y",
        "@google-cloud/run-mcp"
      ],
      "env": {}
    },
    "googlemaps_code_assist": {
      "command": "npx",
      "args": [
        "-y",
        "@googlemaps/code-assist"
      ],
      "env": {}
    },
    "line_bot": {
      "command": "npx",
      "args": [
        "-y",
        "@line/line-bot-mcp-server"
      ],
      "env": {
        "LINE_CHANNEL_ACCESS_TOKEN": "{{LINE_CHANNEL_ACCESS_TOKEN}}",
        "LINE_DESTINATION_USER_ID": "{{LINE_DESTINATION_USER_ID}}"
      }
    },
    "microsoft_clarity": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.clarity.microsoft.com/mcp",
        "--header",
        "X-API-Key:{{CLARITY_API_KEY}}"
      ],
      "env": {}
    },
    "mongodb": {
      "command": "npx",
      "args": [
        "-y",
        "mongodb-mcp-server"
      ],
      "env": {
        "MDB_MCP_CONNECTION_STRING": "{{MDB_MCP_CONNECTION_STRING}}"
      }
    },
    "notion": {
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_API_KEY": "{{NOTION_API_KEY}}"
      }
    },
    "terraform": {
      "command": "terraform-mcp-server",
      "args": [],
      "env": {}
    },
    "webflow": {
      "command": "{{WEBFLOW_MCP_COMMAND}}",
      "args": {{WEBFLOW_MCP_ARGS}},
      "env": {}
    },
    "davinci_resolve": {
      "command": "npx",
      "args": [
        "-y",
        "davinci-resolve-mcp"
      ],
      "env": {}
    },
    "gemini_cloud_assist": {
      "command": "npx",
      "args": [
        "-y",
        "@google-cloud/gemini-cloud-assist-mcp@latest"
      ],
      "env": {}
    },
    "codegraphcontext": {
      "command": "cgc",
      "args": [
        "mcp",
        "start"
      ],
      "env": {}
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "{{CONTEXT7_API_KEY}}"
      }
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "{{FIRECRAWL_API_KEY}}"
      }
    },
    "figma_context_mcp": {
      "command": "npx",
      "args": [
        "-y",
        "figma-developer-mcp",
        "--stdio"
      ],
      "env": {
        "FIGMA_API_KEY": "{{FIGMA_API_KEY}}"
      }
    },
    "jina_reader": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.jina.ai/v1"
      ],
      "env": {}
    }
  }
}
