apiVersion: serving.knative.dev/v1
kind: Service
metadata:
  name: ai-config-selector
  namespace: "{{PROJECT_NUMBER}}"
  labels:
    cloud.googleapis.com/location: {{REGION}}
  annotations:
    run.googleapis.com/ingress: all
    run.googleapis.com/invoker-iam-disabled: "true"
    run.googleapis.com/maxScale: "1"
spec:
  template:
    metadata:
      labels:
        run.googleapis.com/startupProbeType: Default
      annotations:
        autoscaling.knative.dev/maxScale: "1"
        run.googleapis.com/execution-environment: gen2
        run.googleapis.com/startup-cpu-boost: "true"
        ai-config.dev/commit-sha: "{{SELECTOR_COMMIT_SHA}}"
        ai-config.dev/image-ref: "{{SELECTOR_IMAGE}}"
    spec:
      containerConcurrency: 5
      timeoutSeconds: 900
      serviceAccountName: {{SERVICE_ACCOUNT}}
      containers:
      - name: ai-config-selector-1
        image: {{SELECTOR_IMAGE}}
        ports:
        - name: http1
          containerPort: 8080
        env:
        - name: AI_CONFIG_DEPLOY_COMMIT_SHA
          value: "{{SELECTOR_COMMIT_SHA}}"
        - name: AI_CONFIG_DEPLOY_IMAGE
          value: "{{SELECTOR_IMAGE}}"
        resources:
          limits:
            cpu: 1000m
            memory: 1Gi
        livenessProbe:
          timeoutSeconds: 240
          periodSeconds: 240
          failureThreshold: 1
          httpGet:
            path: /healthz
            port: 8080
        startupProbe:
          timeoutSeconds: 240
          periodSeconds: 240
          failureThreshold: 1
          tcpSocket:
            port: 8080
  traffic:
  - percent: 100
    latestRevision: true
