model = "gpt-5.3-codex"
model_reasoning_effort = "xhigh"

[mcp_servers.fetch]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-fetch"]

[mcp_servers.git]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-git"]

[mcp_servers.memory]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-memory"]

[mcp_servers.sequential_thinking]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-sequential-thinking"]

[mcp_servers.time]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-time", "--local-timezone={{MCP_LOCAL_TIMEZONE}}"]

[mcp_servers.gdrive]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-gdrive"]

[mcp_servers.google_maps]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-google-maps"]
env = { GOOGLE_MAPS_API_KEY = "{{GOOGLE_MAPS_API_KEY}}" }

[mcp_servers.postgres]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-postgres", "{{POSTGRES_CONNECTION_STRING}}"]

[mcp_servers.slack]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-slack"]
env = { SLACK_BOT_TOKEN = "{{SLACK_BOT_TOKEN}}", SLACK_TEAM_ID = "{{SLACK_TEAM_ID}}" }

[mcp_servers.sqlite]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-sqlite", "{{SQLITE_DB_PATH}}"]

[mcp_servers.playwright]
command = "npx"
args = ["-y", "@playwright/mcp@latest"]

[mcp_servers.chrome_devtools]
command = "npx"
args = ["-y", "chrome-devtools-mcp@latest"]

[mcp_servers.figma]
url = "https://mcp.figma.com/mcp"

[mcp_servers.github]
command = "docker"
args = ["run", "-i", "--rm", "-e", "GITHUB_PERSONAL_ACCESS_TOKEN", "ghcr.io/github/github-mcp-server"]
env = { GITHUB_PERSONAL_ACCESS_TOKEN = "{{GITHUB_PERSONAL_ACCESS_TOKEN}}" }

[mcp_servers.apify]
command = "npx"
args = ["-y", "@apify/actors-mcp-server"]
env = { APIFY_TOKEN = "{{APIFY_TOKEN}}" }

[mcp_servers.box]
command = "npx"
args = ["-y", "@box/mcp-server-box"]
env = { BOX_CLIENT_ID = "{{BOX_CLIENT_ID}}", BOX_CLIENT_SECRET = "{{BOX_CLIENT_SECRET}}", BOX_ENTERPRISE_ID = "{{BOX_ENTERPRISE_ID}}", BOX_USER_ID = "{{BOX_USER_ID}}", BOX_PUBLIC_KEY_ID = "{{BOX_PUBLIC_KEY_ID}}", BOX_PRIVATE_KEY = "{{BOX_PRIVATE_KEY}}", BOX_PASSPHRASE = "{{BOX_PASSPHRASE}}", BOX_APP_SETTINGS_JSON = "{{BOX_APP_SETTINGS_JSON}}", BOX_ACCESS_TOKEN = "{{BOX_ACCESS_TOKEN}}" }

[mcp_servers.canva]
command = "npx"
args = ["-y", "@canva/dev-mcp-server"]

[mcp_servers.firebase]
command = "npx"
args = ["-y", "firebase-tools", "experimental:mcp"]
env = { FIREBASE_TOKEN = "{{FIREBASE_TOKEN}}" }

[mcp_servers.cloud_run]
command = "npx"
args = ["-y", "@google-cloud/run-mcp"]

[mcp_servers.googlemaps_code_assist]
command = "npx"
args = ["-y", "@googlemaps/code-assist"]

[mcp_servers.line_bot]
command = "npx"
args = ["-y", "@line/line-bot-mcp-server"]
env = { LINE_CHANNEL_ACCESS_TOKEN = "{{LINE_CHANNEL_ACCESS_TOKEN}}", LINE_DESTINATION_USER_ID = "{{LINE_DESTINATION_USER_ID}}" }

[mcp_servers.microsoft_clarity]
command = "npx"
args = ["-y", "mcp-remote", "https://mcp.clarity.microsoft.com/mcp", "--header", "X-API-Key:{{CLARITY_API_KEY}}"]

[mcp_servers.mongodb]
command = "npx"
args = ["-y", "mongodb-mcp-server"]
env = { MDB_MCP_CONNECTION_STRING = "{{MDB_MCP_CONNECTION_STRING}}" }

[mcp_servers.notion]
command = "npx"
args = ["-y", "@notionhq/notion-mcp-server"]
env = { NOTION_API_KEY = "{{NOTION_API_KEY}}" }

[mcp_servers.terraform]
command = "terraform-mcp-server"

[mcp_servers.webflow]
command = "{{WEBFLOW_MCP_COMMAND}}"
args = {{WEBFLOW_MCP_ARGS}}

[mcp_servers.davinci_resolve]
command = "npx"
args = ["-y", "davinci-resolve-mcp"]

[mcp_servers.gemini_cloud_assist]
command = "npx"
args = ["-y", "@google-cloud/gemini-cloud-assist-mcp@latest"]

[mcp_servers.codegraphcontext]
command = "cgc"
args = ["mcp", "start"]

[mcp_servers.context7]
command = "npx"
args = ["-y", "@upstash/context7-mcp"]
env = { CONTEXT7_API_KEY = "{{CONTEXT7_API_KEY}}" }

[mcp_servers.firecrawl]
command = "npx"
args = ["-y", "firecrawl-mcp"]
env = { FIRECRAWL_API_KEY = "{{FIRECRAWL_API_KEY}}" }

[mcp_servers.figma_context_mcp]
command = "npx"
args = ["-y", "figma-developer-mcp", "--stdio"]
env = { FIGMA_API_KEY = "{{FIGMA_API_KEY}}" }

[mcp_servers.jina_reader]
command = "npx"
args = ["-y", "mcp-remote", "https://mcp.jina.ai/v1"]
